{
  "name": "scheduler-service",
  "version": "1.0.0",
  "description": "Scheduled tasks microservice (BullMQ + Redis) — agnostic publisher to RabbitMQ",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push --accept-data-loss --skip-generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@bull-board/api": "^6.4.0",
    "@bull-board/express": "^6.4.0",
    "@bull-board/nestjs": "^6.4.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "amqplib": "^0.10.3",
    "bullmq": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron-parser": "^4.9.0",
    "express": "^4.18.0",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/amqplib": "^0.10.1",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
